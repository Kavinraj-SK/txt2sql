{
  "name": "txt2sql",
  "version": "1.0.0",
  "description": "Natural-language to SQL engine powered by Claude AI and MySQL 9.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite client",
    "build": "vite build client",
    "start": "node server/index.js",
    "db:schema": "mysql -u$DB_USER -p$DB_PASSWORD $DB_NAME < database/schema.sql",
    "db:seed": "mysql -u$DB_USER -p$DB_PASSWORD $DB_NAME < database/seed.sql",
    "db:setup": "npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "mysql2": "^3.9.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "vite": "^5.2.11"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
